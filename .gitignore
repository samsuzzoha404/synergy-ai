# =============================================================================
# Synergy AI — Root .gitignore
# =============================================================================

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/

# Environment & secrets — NEVER commit
.env
.env.*
!.env.example
*.local

# Python virtual environments (root level)
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*.pyd

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
*.pem

# Testing
coverage/

# TypeScript
*.tsbuildinfo
.vercel
