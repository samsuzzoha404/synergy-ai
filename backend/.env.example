# =============================================================================
# Synergy Sales Genius — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# For Azure: set these as Application Settings (Container Apps / App Service).
# =============================================================================

# ===========================================================================
# REQUIRED — App will NOT start without these
# ===========================================================================

# --- Azure Cosmos DB (REQUIRED) ---
AZURE_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
AZURE_COSMOS_KEY=<your-cosmos-primary-key>

# --- Azure OpenAI (REQUIRED) ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-02-01

# --- JWT Authentication (REQUIRED in production) ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<replace-with-a-strong-random-secret-at-least-32-chars>

# ===========================================================================
# OPTIONAL — Defaults are shown; override as needed
# ===========================================================================

# --- Azure Cosmos DB container / database names ---
COSMOS_DATABASE_NAME=SynergyDB
COSMOS_CONTAINER_LEADS=Leads
COSMOS_CONTAINER_CONFLICTS=Conflicts
COSMOS_CONTAINER_USERS=Users
COSMOS_CONTAINER_ACTIVITIES=Activities
COSMOS_CONTAINER_AUDIT=AuditLogs

# --- Cosmos DB throughput ---
# COSMOS_THROUGHPUT_MODE: "autoscale" (default) | "manual"
COSMOS_THROUGHPUT_MODE=autoscale
COSMOS_AUTOSCALE_MAX_RU=4000
COSMOS_MANUAL_RU=1000
# Set to "false" for read-only RBAC accounts or serverless Cosmos DB
COSMOS_CONFIGURE_THROUGHPUT=true

# --- Azure OpenAI Deployment Names ---
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_EMBEDDING_API_VERSION=2023-05-15

# --- CORS (set to your Azure Static Web Apps URL in production) ---
# Example: ALLOWED_ORIGINS=https://your-app.azurestaticapps.net
ALLOWED_ORIGINS=https://<your-static-web-app>.azurestaticapps.net

# --- JWT token expiry ---
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- API documentation (set to "true" only for development/debugging) ---
ENABLE_DOCS=false

# --- Rate limiting overrides ---
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_WRITE=30/minute
RATE_LIMIT_BULK=5/minute
RATE_LIMIT_PATCH=60/minute
RATE_LIMIT_READ=200/minute

# --- Uvicorn workers (for Docker / Azure Container Apps) ---
UVICORN_WORKERS=4

# ===========================================================================
# OPTIONAL — Email Notifications (leave blank to disable)
# ===========================================================================
# Generate a Gmail App Password at: Google Account → Security → App passwords
NOTIFY_EMAIL_FROM=your-gmail@gmail.com
NOTIFY_SMTP_PASSWORD=<gmail-app-password-16-chars>
NOTIFY_EMAIL_TO=manager@chinhin.com,sales-lead@chinhin.com
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587

# ===========================================================================
# OPTIONAL — Azure Application Insights (telemetry & monitoring)
# ===========================================================================
# Find the connection string in: Azure Portal → App Insights → Overview
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
APPLICATIONINSIGHTS_SAMPLE_RATE=1.0
OTEL_SERVICE_NAME=synergy-sales-genius-api
